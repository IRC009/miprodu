{
  "expo": {
    "name": "MiProdu",
    "slug": "miprodu",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/icono.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/icono.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "androidNavigationBar": {
      "visible": "always",
      "barStyle": "dark-content",
      "backgroundColor": "#ffffff"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification_icon.png",
          "color": "#C9A227",
          "androidMode": "default",
          "androidCollapsedTitle": "Nuevo Pedido",
          "iosDisplayInForeground": true,
          "sounds": [
            "./assets/order_chime.mp3"
          ]
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.miprodu.app",
      "buildNumber": "1"
    },
    "android": {
      "package": "com.miprodu.app",
      "versionCode": 2,
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "irc009",
    "extra": {
      "eas": {
        "projectId": "127a63af-a338-45b6-924d-be453ec06e04"
      }
    }
  }
}
