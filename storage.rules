rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Comprobantes de pago: subida pública (no requiere auth en menú), lectura pública
    match /receipts/{restaurantId}/{fileName} {
      // Cualquiera puede subir (cliente desde el menú público sin login)
      allow write: if request.resource.size < 10 * 1024 * 1024  // máx 10 MB
                   && request.resource.contentType.matches('image/.*');
      // Cualquiera puede leer (restaurante lo abre en el dash)
      allow read: if true;
    }

    // Todo lo demás requiere autenticación
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
